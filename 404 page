<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>404 | Raihan Hossen</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#050505;
    color:#fff;
    font-family:Arial,Helvetica,sans-serif;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    overflow:hidden;
}

.container{
    text-align:center;
    padding:20px;
}

h1{
    font-size:120px;
    color:#ff8c00;
    text-shadow:0 0 30px rgba(255,140,0,.5);
}

h2{
    margin:10px 0;
    font-size:34px;
}

p{
    color:#ccc;
    margin:20px 0 35px;
    line-height:1.7;
}

a{
    display:inline-block;
    text-decoration:none;
    color:#fff;
    background:#ff8c00;
    padding:14px 35px;
    border-radius:50px;
    font-weight:bold;
    transition:.3s;
}

a:hover{
    background:#ffa733;
    transform:translateY(-3px);
}

.glow{
    position:absolute;
    width:400px;
    height:400px;
    background:#ff8c00;
    filter:blur(180px);
    opacity:.15;
    border-radius:50%;
    z-index:-1;
}
</style>

</head>
<body>

<div class="glow"></div>

<div class="container">
    <h1>404</h1>
    <h2>Page Not Found</h2>

    <p>
        Sorry, the page you're looking for doesn't exist or has been moved.
    </p>

    <a href="/">← Back to Home</a>
</div>

</body>
</html>
